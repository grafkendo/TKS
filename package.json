{
  "name": "tackticus",
  "version": "0.1.0",
  "description": "Tackticus — 2-player tactical abstract. Build targets: local hot-seat, optional networked self-host, Board Game Arena.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:local": "vite build",
    "build:coop": "vite build --config vite.coop.config.ts",
    "build:all": "npm run build:local && npm run build:coop",
    "dev:coop": "npm-run-all --parallel dev server",
    "preview:local": "vite preview",
    "build:bga:ts": "rollup -c",
    "build:bga:scss": "sass --no-source-map src/scss/tackticus.scss tackticus.css",
    "build:bga": "npm run build:bga:ts && npm run build:bga:scss",
    "watch:bga": "npm-run-all --parallel \"build:bga:ts -- -w\" \"build:bga:scss -- --watch\"",
    "server": "node server/index.mjs",
    "share": "node scripts/share.mjs",
    "share:lan": "node scripts/share.mjs --lan-only",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "^22.5.0",
    "@types/ws": "^8.5.12",
    "npm-run-all": "^4.1.5",
    "rollup": "^4.21.0",
    "sass": "^1.78.0",
    "tslib": "^2.7.0",
    "typescript": "^5.5.4",
    "localtunnel": "^2.0.2",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "three": "^0.184.0",
    "ws": "^8.18.0"
  }
}
